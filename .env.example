# =============================================================================
# Aura eCommerce — environment template. Copy to `.env` and fill real values.
#   cp .env.example .env
# Never commit the real `.env`.
# =============================================================================

# --- Application -------------------------------------------------------------
NODE_ENV=development
# Port the backend API listens on (matches the frontend contract: :5001/api).
PORT=5001

# CORS — comma separated list of allowed origins, or * for all.
CORS_ORIGIN=*

# --- JWT ---------------------------------------------------------------------
# Use a long, random, secret string in every real environment.
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# --- MySQL -------------------------------------------------------------------
# Use `localhost` for local dev; use `db` when running via docker-compose.
DB_HOST=localhost
DB_PORT=3306
DB_USER=aura
DB_PASSWORD=aura_password
DB_NAME=aura
DB_CONNECTION_LIMIT=10
# Root password used only by the MySQL container at first boot.
MYSQL_ROOT_PASSWORD=root_password

# --- Frontend ----------------------------------------------------------------
# Base URL of the backend API as seen from the browser (build-time for Vite).
VITE_API_URL=http://localhost:5001/api
