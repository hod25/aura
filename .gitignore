# =============================================================================
# Aura monorepo .gitignore (Node/TypeScript backend + React frontend + MySQL)
# =============================================================================

# --- Dependencies ------------------------------------------------------------
node_modules/
**/node_modules/
.pnp
.pnp.js
.npm
.yarn-integrity
.pnpm-store/

# --- Build / compile output --------------------------------------------------
dist/
**/dist/
build/
**/build/
dist-ssr/
out/
*.tsbuildinfo
.vite/

# --- Environment & secrets ---------------------------------------------------
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- Local MySQL docker volume / database storage ----------------------------
# (in case the db volume is bind-mounted into the repo instead of a named volume)
data/
mysql-data/
db-data/
docker/mysql/data/
*.sqlite
*.sqlite3
*.db

# --- Logs --------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test / coverage ---------------------------------------------------------
coverage/
.nyc_output/

# --- Caches ------------------------------------------------------------------
.cache/
.eslintcache
.parcel-cache/

# --- Editor / OS -------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
